        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (app) (count_over_time({namespace=\"$namespace\", app=\"$app\"} |~ \"(?i)(error|err|exception|fatal|panic)\" [$__auto]))",
          "legendFormat": "{{app}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Erros por app ao longo do tempo",
      "type": "timeseries"
