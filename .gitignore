# Terraform — cache local, state e variáveis
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
!*.tfvars.example
# .terraform.lock.hcl é versionado — garante providers reprodutíveis

# Chaves SSH geradas pelo Terraform — nunca versionar
.ssh/

# Ansible — inventário com IPs e paths locais
ansible/inventory/hosts.ini
# Credenciais geradas pelos playbooks
ansible/files/*-credentials.yml

# Informações locais (IPs, paths, credenciais)
CLAUDE.local.md

# Ambiente Python local para ferramentas/Ansible
.venv/

# Arquivos temporários
*.log
*.tmp
